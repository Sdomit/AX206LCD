{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@dash": ["../engine/src/dashboard/index.ts"],
      "@engine/*": ["../engine/src/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
